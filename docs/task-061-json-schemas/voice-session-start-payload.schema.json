{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hexe.local/docs/task-061-json-schemas/voice-session-start-payload.schema.json",
  "title": "HexeVoice Session Start Payload",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "firmware_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "wake_source": {
      "type": "string",
      "enum": [
        "openwakeword",
        "button",
        "manual",
        "unknown"
      ],
      "default": "unknown"
    },
    "audio_format": {
      "$ref": "#/$defs/audio_format"
    }
  },
  "$defs": {
    "audio_format": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "encoding": {
          "type": "string",
          "enum": [
            "pcm_s16le",
            "opus",
            "wav"
          ],
          "default": "pcm_s16le"
        },
        "sample_rate_hz": {
          "type": "integer",
          "minimum": 8000,
          "default": 16000
        },
        "channels": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2,
          "default": 1
        }
      }
    }
  }
}
