{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hexe.local/docs/task-061-json-schemas/endpoint-ota-update-payload.schema.json",
  "title": "HexeVoice Endpoint OTA Update Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "url"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "url": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": [
        "string",
        "null"
      ]
    },
    "sha256": {
      "type": [
        "string",
        "null"
      ]
    },
    "size_bytes": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    }
  }
}
