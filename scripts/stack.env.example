BACKEND_CMD="API_HOST=0.0.0.0 API_PORT=9004 PUBLIC_API_BASE_URL=http://10.0.0.100:9004 HEXE_SUPERVISOR_ENABLED=true HEXE_SUPERVISOR_API_TRANSPORT=socket HEXE_SUPERVISOR_API_SOCKET=/run/hexe/supervisor.sock PYTHONPATH=src .venv/bin/python -m hexevoice.main"
FRONTEND_CMD="cd frontend && VITE_PROXY_TARGET=http://127.0.0.1:9004 npm run dev -- --host 0.0.0.0 --port 8080"
BACKEND_SERVICE_NAME="hexevoice-backend.service"
FRONTEND_SERVICE_NAME="hexevoice-frontend.service"
