BACKEND_CMD="API_HOST=0.0.0.0 API_PORT=9004 PUBLIC_API_BASE_URL=http://10.0.0.100:9004 HEXE_SUPERVISOR_ENABLED=true HEXE_SUPERVISOR_API_TRANSPORT=socket HEXE_SUPERVISOR_API_SOCKET=/run/hexe/supervisor.sock HEXE_SUPERVISOR_API_TIMEOUT_S=8 VOICE_WAKE_PROVIDER=supervised_openwakeword VOICE_WAKE_SERVICE_HOST=127.0.0.1 VOICE_WAKE_SERVICE_PORT=10400 VOICE_WAKE_MODELS=Hexa VOICE_WAKE_RECORDINGS_ENABLED=true VOICE_WAKE_RECORDING_RETENTION_DAYS=7 VOICE_WAKE_RECORDING_PREROLL_MS=2000 VOICE_MICRO_VAD_CHUNKS_ENABLED=false VOICE_MICRO_VAD_CHUNK_RETENTION_DAYS=1 VOICE_SESSION_HISTORY_LIMIT=100 VOICE_STT_PROVIDER=external_faster_whisper VOICE_STT_SERVICE_HOST=127.0.0.1 VOICE_STT_SERVICE_PORT=10300 VOICE_STT_PRELOAD=true VOICE_STT_FASTER_WHISPER_MODEL=base.en VOICE_STT_FASTER_WHISPER_DEVICE=cpu VOICE_STT_FASTER_WHISPER_COMPUTE_TYPE=int8 VOICE_STT_FASTER_WHISPER_LANGUAGE=en VOICE_STT_FASTER_WHISPER_BEAM_SIZE=5 VOICE_STT_FASTER_WHISPER_BEST_OF=5 VOICE_STT_FASTER_WHISPER_WITHOUT_TIMESTAMPS=true VOICE_STT_FASTER_WHISPER_WORD_TIMESTAMPS=false VOICE_STT_FASTER_WHISPER_MAX_INITIAL_TIMESTAMP=1.0 VOICE_TTS_PROVIDER=piper VOICE_TTS_PIPER_SERVICE_HOST=127.0.0.1 VOICE_TTS_PIPER_SERVICE_PORT=10200 VOICE_TTS_OUTPUT_SAMPLE_RATE_HZ=48000 VOICE_TTS_ENDPOINT_SAMPLE_RATES=esp-pe-1=48000,esp-box-1=16000 VOICE_TTS_ENDPOINT_VOICES=esp-pe-1=en_US-lessac-high PYTHONPATH=src .venv/bin/python -m hexevoice.main"
STT_CMD="VOICE_STT_SERVICE_HOST=127.0.0.1 VOICE_STT_SERVICE_PORT=10300 VOICE_STT_FASTER_WHISPER_MODEL=base.en VOICE_STT_FASTER_WHISPER_DEVICE=cpu VOICE_STT_FASTER_WHISPER_COMPUTE_TYPE=int8 VOICE_STT_FASTER_WHISPER_LANGUAGE=en VOICE_STT_FASTER_WHISPER_BEAM_SIZE=5 VOICE_STT_FASTER_WHISPER_BEST_OF=5 VOICE_STT_FASTER_WHISPER_WITHOUT_TIMESTAMPS=true VOICE_STT_FASTER_WHISPER_WORD_TIMESTAMPS=false VOICE_STT_FASTER_WHISPER_MAX_INITIAL_TIMESTAMP=1.0 PYTHONPATH=src .venv/bin/python -m stt.service"
FRONTEND_CMD="cd frontend && VITE_PROXY_TARGET=http://127.0.0.1:9004 npm run dev -- --host 0.0.0.0 --port 8084"
BACKEND_SERVICE_NAME="hexevoice-backend.service"
STT_SERVICE_NAME="hexevoice-stt.service"
FRONTEND_SERVICE_NAME="hexevoice-frontend.service"
