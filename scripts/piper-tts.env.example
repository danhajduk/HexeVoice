PIPER_TTS_IMAGE=hexevoice/piper-tts:local
PIPER_TTS_CONTAINER_NAME=hexevoice-piper-tts
PIPER_TTS_PORT=10200
PIPER_TTS_MODEL_DIR=./runtime/piper-tts/models
PIPER_TTS_MODEL_PATH=/models/en_US-lessac-medium.onnx
PIPER_TTS_WARM_VOICES=en_GB-jenny_dioco-medium
