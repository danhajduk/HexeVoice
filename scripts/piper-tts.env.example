PIPER_TTS_VOICE_REPO_URL=https://huggingface.co/rhasspy/piper-voices/resolve/v1.0.0
PIPER_TTS_CONFIG_PATH=
PIPER_TTS_TIMEOUT_S=30
PIPER_TTS_WARM_TIMEOUT_S=10
PIPER_TTS_WARM_IDLE_S=1.0
